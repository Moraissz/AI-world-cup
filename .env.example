FOOTBALL_IO_SPORTS_API_KEY=your_api_sports_io_key_here
FOOTBALL_DATA_ORG_API_KEY=your_football_data_org_key_here
OMNI_API_URL=http://localhost:8882
OMNI_API_KEY=your_omni_api_key_here

# URL of the FastAPI service (change to Railway URL if deploying FastAPI to cloud)
API_BASE_URL=http://localhost:8000

# Redis (REQUIRED — cache for external APIs + conversation memory).
# Started automatically by `make start` via Docker. No in-memory fallback:
# if unreachable, /memory and data endpoints return 500.
# Production: free credentials at https://upstash.com
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Set to true only for TLS-enabled Redis (e.g. Upstash). Local Docker Redis: false.
REDIS_SSL=false

# Structured logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # use "console" for local dev (human-readable output)
